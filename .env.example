# LLM provider
# Gemini free tier: use Flash. Pro preview is not available on the API free tier.
LLM_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key

# Optional Anthropic alternative:
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# Models
STRATEGIST_MODEL=gemini-3-flash-preview
PLAYER_MODEL=gemini-3-flash-preview
BUILDER_MODEL=gemini-3-flash-preview
LLM_MAX_CONCURRENCY=2

# Database
DATABASE_URL=sqlite:///./cubist.db

# Tournament defaults
TIME_PER_MOVE_MS=20000
GAMES_PER_PAIRING=2
MAX_MOVES_PER_GAME=120

# API
API_HOST=127.0.0.1
API_PORT=8000
